# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Postgres (local docker-compose uses host "postgres"; local dev uses "localhost")
DATABASE_URL=postgresql://agentkit:agentkit@localhost:5432/agentkit

# App LLM backend: "real" (Anthropic, needs key) | "stub" (deterministic, no key — for demos)
APP_LLM=real

# Retrieval
# hashing  = offline, dependency-free, lexical-overlap proxy (default, good for dev/tests)
# fastembed = real semantic embeddings (pip install ".[embed]", one-time model download)
EMBEDDING_PROVIDER=hashing
EMBEDDING_DIM=384
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.25
